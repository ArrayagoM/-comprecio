# ── Comprecio — Variables de entorno ──────────────────────────

# JWT Secret (generá uno aleatorio: openssl rand -base64 32)
JWT_SECRET=cambia_esto_por_algo_secreto_largo

# Base de datos PostgreSQL (Neon)
# Obtené tu URL en: https://neon.tech → New Project → Connection string
DATABASE_URL=postgresql://usuario:contraseña@host/comprecio?sslmode=require

# Puerto local (opcional, por defecto 3000)
PORT=3000

# Email del administrador — este usuario tendrá rol "admin" al iniciar la app
ADMIN_EMAIL=tu@email.com
